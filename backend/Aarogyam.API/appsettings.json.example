{
  "ConnectionStrings": {
    "AarogyamDb": "Server=localhost;Database=AarogyamDB;User Id=SA;Password=YOUR_PASSWORD_HERE;TrustServerCertificate=True;"
  },

  "Email": {
    "SmtpHost": "smtp.gmail.com",
    "SmtpPort": 587,
    "SenderEmail": "your-email@gmail.com",
    "SenderPassword": "your-app-password",
    "SenderName": "Aarogyam"
  },

  "Jwt": {
    "Issuer": "AarogyamAPI",
    "Audience": "AarogyamClient",
    "SecretKey": "REPLACE_WITH_A_LONG_RANDOM_SECRET_AT_LEAST_32_CHARS",
    "ExpiryMinutes": 60
  },

  "Swagger": {
    "Username": "REPLACE_WITH_A_SWAGGER_USERNAME",
    "Password": "REPLACE_WITH_A_SWAGGER_PASSWORD"
  },

  "Storage": {
    "BasePath": "Storage"
  },

  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },

  "AllowedHosts": "*"
}
