# Copy this file to .env on the SERVER (next to docker-compose.yml) and fill
# in real values. This file is loaded automatically by `docker compose`.
# Do not commit the real .env.

# Images pushed by the GitHub Actions workflow (owner/repo names are lowercased)
API_IMAGE=ghcr.io/OWNER/aarogyam-api:latest
FRONTEND_IMAGE=ghcr.io/OWNER/aarogyam-frontend:latest

# Must be reachable from inside the api container - see the note in docker-compose.yml
DB_CONNECTION_STRING=Server=YOUR_SQLSERVER_HOST,1433;Database=AarogyamDB;User Id=SA;Password=YOUR_PASSWORD;TrustServerCertificate=True;

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SENDER_EMAIL=your-email@gmail.com
SMTP_SENDER_PASSWORD=your-app-password

# Generate with: openssl rand -base64 64
JWT_SECRET_KEY=REPLACE_WITH_A_LONG_RANDOM_SECRET_AT_LEAST_32_CHARS

# Only needed if the existing SQL Server container's network is being joined
# (see the commented sqlserver-net block in docker-compose.yml)
SQLSERVER_NETWORK_NAME=
